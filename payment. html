<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Payment - Zenag Game Centre</title>
    <script src="https://js.paystack.co/v1/inline.js"></script>
    <style>
        body {
            font-family: Arial;
            background: #0a0f1e;
            color: white;
            text-align: center;
            padding: 50px;
        }
        button {
            background: #f4a261;
            padding: 15px 30px;
            font-size: 18px;
            border: none;
            border-radius: 40px;
            cursor: pointer;
        }
    </style>
</head>
<body>
    <h2>💳 Complete Payment</h2>
    <p>Amount: 10 GHS (per hour)</p>
    <button onclick="payWithPaystack()">Pay Now with Paystack</button>

    <script>
        function payWithPaystack() {
            let handler = PaystackPop.setup({
                key: 'YOUR_PAYSTACK_PUBLIC_KEY', // Replace with your live/test key
                email: 'customer@example.com', // You can ask for email in booking form
                amount: 10000, // 10 GHS = 10,000 pesewas
                currency: 'GHS',
                ref: 'ZENAG_' + Math.floor((Math.random() * 1000000000) + 1),
                callback: function(response) {
                    alert('Payment successful! Reference: ' + response.reference);
                    window.location.href = 'thankyou.html';
                },
                onClose: function() {
                    alert('Payment window closed.');
                }
            });
            handler.openIframe();
        }
    </script>
</body>
</html>
